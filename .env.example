# ---- Discord ----
# https://discord.com/developers/applications 에서 발급
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
# 길드(서버) 단위로 슬래시 명령을 즉시 등록하려면 설정 (개발용). 비우면 글로벌 등록.
DISCORD_GUILD_ID=

# ---- Database (PostgreSQL) ----
# 방법 A) 연결 문자열 한 줄 (있으면 우선 적용)
# DATABASE_URL=postgres://botuser:password@host:5432/dbname
# 방법 B) 개별 항목
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-password
PGDATABASE=postgres
# 자체 서명 인증서로 SSL 필요 시 true
PGSSL=false

# ---- App ----
PORT=3000
NODE_ENV=production
